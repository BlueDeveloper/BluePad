{
  "$schema": "https://raw.githubusercontent.com/nicosaurus/tauri-schema-generator/main/schema/2.0.0/schema.json",
  "productName": "BluePad",
  "version": "1.14.4",
  "identifier": "brp.bluepad.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "BluePad",
        "width": 1000,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "decorations": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://bluepad-license-api.blueehdwp.workers.dev https://bluepad-download.blueehdwp.workers.dev"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "bannerPath": "wix-banner.bmp",
        "dialogImagePath": "wix-dialog.bmp"
      }
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": ["txt", "log"],
        "mimeType": "text/plain",
        "description": "Text Document",
        "role": "Editor"
      },
      {
        "ext": ["json", "jsonc"],
        "mimeType": "application/json",
        "description": "JSON Document",
        "role": "Editor"
      },
      {
        "ext": ["yaml", "yml"],
        "mimeType": "application/x-yaml",
        "description": "YAML Document",
        "role": "Editor"
      },
      {
        "ext": ["js", "jsx", "mjs", "cjs", "ts", "tsx"],
        "mimeType": "text/javascript",
        "description": "JavaScript / TypeScript Source",
        "role": "Editor"
      },
      {
        "ext": ["html", "htm", "xhtml"],
        "mimeType": "text/html",
        "description": "HTML Document",
        "role": "Editor"
      },
      {
        "ext": ["css", "scss", "sass", "less"],
        "mimeType": "text/css",
        "description": "CSS Stylesheet",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2NDFDNTEwMTNEQjAyRApSV1F0c0QwQlVSeGtEai9iMU1DZmR1KzFSenB3cTdPVkFFU0VNeUpFZXBmVW9yYlF4anBBc3hqego=",
      "endpoints": [
        "https://bluepad-download.blueehdwp.workers.dev/update.json"
      ]
    }
  }
}
